{
  "appId": "pl.bastion.enterprise",
  "productName": "BASTION",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.utilities",
    "icon": "public/icon.icns"
  },
  "win": {
    "target": ["nsis"],
    "icon": "public/icon.png",
    "artifactName": "BASTION-Setup-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Utility",
    "icon": "public/icon.png",
    "artifactName": "BASTION-${version}-${arch}.${ext}",
    "desktop": {
      "Name": "BASTION",
      "Comment": "Operational intelligence for critical infrastructure",
      "Categories": "Utility;Security;"
    }
  }
}
