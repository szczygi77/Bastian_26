{
  "appId": "pl.bastion.enterprise",
  "productName": "BASTION",
  "copyright": "Copyright © 2026 SpaceShield / m&m",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist-electron/main.js"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      }
    ],
    "category": "public.app-category.utilities",
    "icon": "public/icon.icns",
    "artifactName": "BASTION-${version}-mac-${arch}.${ext}",
    "hardenedRuntime": false
  },
  "dmg": {
    "title": "BASTION ${version}",
    "artifactName": "BASTION-${version}-mac-${arch}.${ext}"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png",
    "artifactName": "BASTION-${version}-win-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "BASTION",
    "installerLanguages": ["pl_PL", "en_US"],
    "language": "1045",
    "artifactName": "BASTION-Setup-${version}-win-${arch}.${ext}"
  },
  "portable": {
    "artifactName": "BASTION-Portable-${version}-win-${arch}.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "rpm",
        "arch": ["x64"]
      },
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "category": "Utility;Security;",
    "icon": "public/icon.png",
    "artifactName": "BASTION-${version}-linux-${arch}.${ext}",
    "desktop": {
      "entry": {
        "Name": "BASTION",
        "Comment": "Operational intelligence for critical infrastructure",
        "Categories": "Utility;Security;Network;",
        "StartupWMClass": "bastion"
      }
    },
    "synopsis": "Centrum dowodzenia BASTION — infrastruktura krytyczna",
    "description": "Offline-first platforma świadomości sytuacyjnej dla infrastruktury krytycznej (Stalowa Wola / Podkarpackie demo).",
    "maintainer": "SpaceShield <bastion@spaceshield.pl>",
  },
  "rpm": {
    "depends": [
      "libXScrnSaver",
      "libXtst",
      "libnotify",
      "nss",
      "alsa-lib",
      "gtk3"
    ],
    "fpm": [
      "--rpm-rpmbuild-define",
      "_build_id_links none"
    ]
  }
}
